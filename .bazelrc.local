# Nix-specific paths for libraries and includes
build --action_env=BAZEL_USE_CPP_ONLY_TOOLCHAIN=1
build --action_env=CC=/nix/store/dmypp1h4ldn0vfk3fi6yfyf5yxp9yz0k-gcc-wrapper-14.3.0/bin/gcc
build --action_env=CXX=/nix/store/dmypp1h4ldn0vfk3fi6yfyf5yxp9yz0k-gcc-wrapper-14.3.0/bin/g++

# Library paths
build --linkopt=-L/nix/store/nhn2bjwsbjgj5m0qd0py9fzz13q7yjzz-libx11-1.8.12/lib
build --linkopt=-L/nix/store/3gpdyj3b41i1n8sf6x7ldalv03xb01d8-libxext-1.3.6/lib
build --linkopt=-L/nix/store/6qi8skh85ci2k9gvl27nnh3kiy32qnsz-zlib-1.3.1/lib
build --linkopt=-L/nix/store/v4a7n4azmkjgcxcdyx5pn5y71znjfvsa-libbsd-0.12.2/lib

# Include paths - use isystem to avoid sandbox issues
build --copt=-isystem/nix/store/v1pl71901nmcf57d4fsnmjb10r7z32m6-libx11-1.8.12-dev/include
build --copt=-isystem/nix/store/i0jc5ms3bzb8sc7iw8a620vbkl2n6xmh-libxext-1.3.6-dev/include
build --copt=-isystem/nix/store/gd1i6p712i3mbniq9ynmqzzx8l21h5qq-xorgproto-2024.1/include
build --copt=-isystem/nix/store/6fqij3sy1mlsnq1n679bzbl5bkqs7yvk-zlib-1.3.1-dev/include
build --copt=-isystem/nix/store/v4a7n4azmkjgcxcdyx5pn5y71znjfvsa-libbsd-0.12.2/include

# Runtime library paths
build --linkopt=-Wl,-rpath,/nix/store/nhn2bjwsbjgj5m0qd0py9fzz13q7yjzz-libx11-1.8.12/lib
build --linkopt=-Wl,-rpath,/nix/store/3gpdyj3b41i1n8sf6x7ldalv03xb01d8-libxext-1.3.6/lib
build --linkopt=-Wl,-rpath,/nix/store/6qi8skh85ci2k9gvl27nnh3kiy32qnsz-zlib-1.3.1/lib
build --linkopt=-Wl,-rpath,/nix/store/v4a7n4azmkjgcxcdyx5pn5y71znjfvsa-libbsd-0.12.2/lib
